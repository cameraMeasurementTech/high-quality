# Local smoke-test secrets (do not commit)
# Copy to .env and fill in.

# HuggingFace (gated models + DINO)
HF_TOKEN=

# Cloudflare R2 (S3 API)
R2_ACCOUNT_ID=
# Or set full endpoint instead of account id:
# R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public HTTPS base that serves the bucket (custom domain or r2.dev)
CDN_PUBLIC_BASE=https://cdn.example.com
