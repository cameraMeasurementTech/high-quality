# Standalone workspace — copy to training/.env and edit keys.
#
# NEW MACHINE — run first:
#   cp .env.template .env
#   ./run/00_configure_profile.sh h200x2-dpo   # see MACHINE_PROFILES.md
#   ./run/run_all.sh

# --- Machine profile (applied by 00_configure_profile.sh) ---
# MACHINE_PROFILE=h200x2-dpo
# Profiles: smoke | h100x2-dpo | h200x2-dpo | h100x4-grpo | h200x2-grpo | h200x8-fullft | train-only

# --- Workspace (auto-detected if unset) ---
# WORKSPACE_ROOT=/path/to/workspace
# SHINY_GUIDE_ROOT=/path/to/workspace/shiny-guide
# TRAINING_ROOT=/path/to/workspace/training

# --- Bootstrap sources (used by 00_bootstrap_assets.sh) ---
SHINY_GUIDE_REPO=https://github.com/mokabetrade/shiny-guide.git
SHINY_GUIDE_REF=main
PROMPTS_URL=https://raw.githubusercontent.com/cameraMeasurementTech/image-three.js-localeval/main/prompts.txt
CODER_MODEL_ID=Tooony133/Qwen-3.6-27B-AstroWolf
MODEL_DIR=
# PROMPTS_POOL=   # set automatically after bootstrap

# --- Local coder model (filled by bootstrap if MODEL_DIR empty) ---
# MODEL_PATH=/path/to/models/Qwen-3.6-27B-AstroWolf
# CODER_MODEL_PATH=
# HF_HOME defaults to training/data/hf_cache

# --- API keys (required) ---
OPENROUTER_API_KEY=sk-or-v1-...
HF_TOKEN=hf_...

# --- Pipeline ---
PIPELINE_URL=http://127.0.0.1:10006
PROMPTS_ROOT=shiny-guide

# --- Training defaults (override in run_all.sh) ---
# TRAIN=dpo
# TRAIN_N=5000
# VAL_N=300
# DUEL_N=200
# DPO_SAMPLES=4

# --- Install ---
# CUDA_INDEX=https://download.pytorch.org/whl/cu124
# INSTALL_SYSTEM=1

# --- Optional ---
# NODE_BIN=/usr/bin/node
# JUDGE_BASE_URL=https://openrouter.ai/api/v1
# JUDGE_MODEL=google/gemini-2.5-pro-preview
MACHINE_PROFILE=h200x2-dpo
TRAIN=dpo
TRAIN_N=6000
VAL_N=400
DUEL_N=200
DPO_SAMPLES=4
CONFIG=configs/dpo_shiny_27b.yaml
ALIGN=dpo
CONFIG_FILE=pipeline/configuration.local.yaml
WORKSPACE_ROOT=/home/404-gen-subnet/my-agent/training
TRAINING_ROOT=/home/404-gen-subnet/my-agent/training
SHINY_GUIDE_ROOT=/home/404-gen-subnet/my-agent/training/vendor/shiny-guide
PROMPTS_POOL=/home/404-gen-subnet/my-agent/training/data/prompts.txt
MODEL_PATH=/home/404-gen-subnet/my-agent/training/data/models/Qwen-3.6-27B-AstroWolf
HF_HOME=/home/404-gen-subnet/my-agent/training/data/hf_cache
