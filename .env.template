# Standalone workspace — copy to `training/.env` and edit keys.
#
# Full guide: docs/GETTING_STARTED.md
#   1) cp .env.template .env  → set HF_TOKEN (+ OPENROUTER_API_KEY for duel)
#   2) ./run/00_configure_profile.sh h200x4-dpo-duel
#   3) ./run/00_bootstrap_assets.sh   # downloads AstroWolf → data/models/...
#   4) INSTALL_SYSTEM=1 ./run/00_install_all.sh
#   5) Phase A/B dataset prep, then ./run/03_dpo.sh

# --- Quick start (only this training/ folder required) ---
#   cp .env.template .env
#   ./run/00_configure_profile.sh h200x4-dpo-duel
#   # set HF_TOKEN + OPENROUTER_API_KEY
#   ./run/00_verify_standalone.sh
#   INSTALL_SYSTEM=1 ./run/run_all.sh

# --- Machine profile ---
# MACHINE_PROFILE=h200x4-dpo-duel
# Profiles: smoke | h100x2-dpo | h200x2-dpo | h200x4-dpo | h200x4-dpo-duel | h100x4-grpo | h200x2-grpo | h200x8-fullft | train-only

# --- Paths (relative; everything under training/) ---
# CONFIG_FILE=pipeline/configuration.local.yaml
# SHINY_GUIDE_ROOT is set by bootstrap to training/vendor/shiny-guide
# PROMPTS_POOL=data/prompts.txt
# MODEL_PATH=data/models/Qwen-3.6-27B-AstroWolf

# --- Coder base model (see docs/CODER_MODEL.md) ---
# HuggingFace: Tooony133/Qwen-3.6-27B-AstroWolf
# Default save path after bootstrap:
#   training/data/models/Qwen-3.6-27B-AstroWolf/
# Download: ./run/00_bootstrap_assets.sh  (needs HF_TOKEN below)
CODER_MODEL_ID=Tooony133/Qwen-3.6-27B-AstroWolf
# MODEL_DIR=/path/to/training/data/models/Qwen-3.6-27B-AstroWolf
# MODEL_PATH=/path/to/training/data/models/Qwen-3.6-27B-AstroWolf

# --- Bootstrap sources (00_bootstrap_assets.sh) ---
SHINY_GUIDE_REPO=https://github.com/mokabetrade/shiny-guide.git
SHINY_GUIDE_REF=main
PROMPTS_URL=https://raw.githubusercontent.com/cameraMeasurementTech/image-three.js-localeval/main/prompts.txt

# --- API keys ---
HF_TOKEN=hf_...
# OPENROUTER_API_KEY=sk-or-v1-...   # optional for cheap DPO; required for duel-scored prep

# --- Pipeline ---
PIPELINE_URL=http://127.0.0.1:10006
PROMPTS_ROOT=shiny-guide

# --- Training (set by profile or override) ---
# TRAIN=dpo
# CONFIG=configs/dpo_shiny_27b_duel.yaml   # duel-scored (h200x4-dpo-duel)
# TRAIN_N=5000
# VAL_N=300
# DUEL_N=200
# DPO_SAMPLES=2              # duel path: 2 JS (seed diversity)
# BATCH_SIZE=96              # stems per /generate (match max_num_seqs; skip_render Phase A)
# SIDECAR_COUNT=16           # Chromium farm for Phase B duel scoring
# DUEL_CONCURRENCY=8         # parallel stems while scoring
# SEED=7
# ALIGN=dpo
# NUM_PROCESSES=4
# JUDGE_CONFIG=pipeline/configuration.duel-judge.yaml

# --- Install ---
# CUDA_INDEX=https://download.pytorch.org/whl/cu124
# INSTALL_SYSTEM=1
