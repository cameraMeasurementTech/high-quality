# Standalone workspace — copy to training/.env and edit keys.
#
#   cp .env.template .env
#   ./run/run_all.sh
#
# Or step-by-step:
#   ./run/00_bootstrap_assets.sh   # clone shiny-guide, prompts.txt, model
#   ./run/00_install_all.sh        # all packages
#   ./pipeline/start-native-bg.sh && ./pipeline/wait-ready.sh
#   ALIGN=dpo ./run/01_prepare_shiny_align.sh
#   CONFIG=configs/dpo_shiny_27b.yaml ./run/03_dpo.sh

# --- Workspace (auto-detected if unset) ---
# WORKSPACE_ROOT=/path/to/workspace
# SHINY_GUIDE_ROOT=/path/to/workspace/shiny-guide
# TRAINING_ROOT=/path/to/workspace/training

# --- Bootstrap sources (used by 00_bootstrap_assets.sh) ---
SHINY_GUIDE_REPO=https://github.com/mokabetrade/shiny-guide.git
SHINY_GUIDE_REF=main
PROMPTS_URL=https://raw.githubusercontent.com/cameraMeasurementTech/image-three.js-localeval/main/prompts.txt
CODER_MODEL_ID=Tooony133/Qwen-3.6-27B-AstroWolf
MODEL_DIR=
# PROMPTS_POOL=   # set automatically after bootstrap

# --- Local coder model (filled by bootstrap if MODEL_DIR empty) ---
# MODEL_PATH=/path/to/models/Qwen-3.6-27B-AstroWolf
# CODER_MODEL_PATH=
# HF_HOME defaults to training/data/hf_cache

# --- API keys (required) ---
OPENROUTER_API_KEY=sk-or-v1-...
HF_TOKEN=hf_...

# --- Pipeline ---
PIPELINE_URL=http://127.0.0.1:10006
PROMPTS_ROOT=shiny-guide

# --- Training defaults (override in run_all.sh) ---
# TRAIN=dpo
# TRAIN_N=5000
# VAL_N=300
# DUEL_N=200
# DPO_SAMPLES=4

# --- Install ---
# CUDA_INDEX=https://download.pytorch.org/whl/cu124
# INSTALL_SYSTEM=1

# --- Optional ---
# NODE_BIN=/usr/bin/node
# JUDGE_BASE_URL=https://openrouter.ai/api/v1
# JUDGE_MODEL=google/gemini-2.5-pro-preview
